@page
@model blogsite.Pages.Posts.DetailsModel

@{
    ViewData["Title"] = Model.Post.Title;
}

<h1>@Model.Post.Title</h1>

<div class="row">
    <div class="col-md-8">
        <p>@Model.Post.Content</p>
    </div>
    <div class="col-md-4">
        <h3>Related posts</h3>
        <ul>
            @if (Model.RelatedPosts.Any())
            {
                @foreach (var relatedPost in Model.RelatedPosts)
                {
                    <li>
                        <a asp-page="/Posts/Details" asp-route-id="@relatedPost.Id">@relatedPost.Title</a>
                    </li>
                }
            }
            else
            {
                <p class="text-muted">No related posts in this category.</p>
            }
        </ul>
    </div>
</div>

<div>
    <a asp-page="./Edit" asp-route-id="@Model.Post.Id">Edit</a> |
    <a asp-page="/Index">Back to List</a>
</div>
